	<parameter name="receipt_id" class="java.lang.String"/>
	<parameter name="customer_name" class="java.lang.String"/>
	<parameter name="nic_number" class="java.lang.String"/>
	<parameter name="phone_number" class="java.lang.String"/>
	<parameter name="address" class="java.lang.String"/>
	<parameter name="total_weight" class="java.lang.Double"/>
	<parameter name="total_amount" class="java.lang.Double"/>
	<parameter name="stamp_fees" class="java.lang.Double"/>
	<parameter name="current_interest" class="java.lang.Double"/>
	<parameter name="net_value" class="java.lang.Double"/>
	<parameter name="ItemsDataSource" class="net.sf.jasperreports.engine.data.JRResultSetDataSource"/>
	<query language="SQL"><![CDATA[SELECT 
    plr.receipt_id,
    plr.customer_name,
    plr.nic_number,
    plr.phone_number,
    plr.address,
    plr.total_weight,
    plr.total_amount,
    plr.stamp_fees,
    plr.current_interest,
    plr.net_value,
    
    pld.item_name,
    pld.weight,
    pld.carat_of_gold,
    pld.price,
    pld.loan_months
    
FROM pawnLoanReceipt plr
LEFT JOIN pawnloan_item_details pld 
    ON plr.receipt_id = pld.loan_id

WHERE plr.receipt_id = $P{receipt_id}]]></query>
	<field name="item_name" class="java.lang.String"/>
